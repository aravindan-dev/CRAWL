# Copy to `.env` and fill in. NEVER commit real credentials.
ALIFF_EMAIL=your_email
ALIFF_PASSWORD=your_password

# Safety: dry run does NOT click final Save (fills + screenshots + logs only).
DRY_RUN=true
# Overwrite existing non-empty fields? Default false (only fills empty fields).
OVERWRITE=false

# Portal
ALIFF_BASE_URL=https://super-admin-v2.aliff.in
ALIFF_LOGIN_URL=https://super-admin-v2.aliff.in/login

# Input file (xlsx or csv) under data/
INPUT_FILE=data/verified-input.xlsx

# Limit rows for staged rollout (0 = no limit). Run 5, then 50, then full.
LIMIT=5

# Process which groups: universities | courses | both
PROCESS=both

# Headless browser? false lets you watch it during dry runs.
HEADLESS=false

# Per-action retry attempts
RETRIES=2
