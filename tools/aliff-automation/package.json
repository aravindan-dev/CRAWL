{
  "name": "aliff-automation",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Safe Playwright automation for Aliff Super Admin data entry (university + course records). Standalone module — not part of the CLG Search workspace.",
  "scripts": {
    "start": "tsx src/main.ts",
    "dry": "cross-env DRY_RUN=true tsx src/main.ts",
    "commit": "cross-env DRY_RUN=false tsx src/main.ts",
    "install:browser": "playwright install chromium",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "playwright": "^1.48.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
