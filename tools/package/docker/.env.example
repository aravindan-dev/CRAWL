# CLG Search — Server Edition config. Copy to ".env" next to docker-compose.server-edition.yml
# and fill in the real values before `docker compose up -d`.

# Private registry that holds the pre-built images (see build-and-push.mjs).
# Example: ghcr.io/your-github-username
REGISTRY=ghcr.io/your-github-username

# Which build to run. The vendor tells you this when they ship an update.
IMAGE_TAG=latest

# A real password — NOT the placeholder below. Generate one, e.g.:
#   openssl rand -base64 24
POSTGRES_PASSWORD=change-me-before-first-boot

# Ports exposed on THIS server. Change only if they collide with something else.
API_PORT=4100
WEB_PORT=3100

# How many pages the crawler fetches / parses in parallel. Raise only if this
# server has the CPU/RAM/network headroom for it (each unit is a real browser
# context under load).
CRAWL_CONCURRENCY=2
PARSE_CONCURRENCY=1

# Session cookies over plain HTTP (the LAN default) must NOT set `secure`, or
# browsers silently refuse to send them and nobody can log in. Set to "true"
# only once you've put HTTPS in front of this server (see ADMIN-GUIDE.md).
COOKIE_SECURE=false

# Shown to users on the lock screen / license errors and in the app footer.
VENDOR_CONTACT="your CLG Search account manager"
