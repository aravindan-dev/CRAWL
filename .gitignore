# dependencies
node_modules/
.pnpm-store/

# build output
dist/
.next/
out/
*.tsbuildinfo

# env
.env
.env.local
.env.*.local

# generated by scripts/preflight.ps1 (host port reconciliation)
scripts/ports.bat

# prisma
packages/database/prisma/*.db

# storage artifacts (crawled proof + exports) — keep dirs, ignore contents
storage/screenshots/*
storage/html/*
storage/text/*
storage/exports/*
!storage/**/.gitkeep

# logs / os
*.log
.DS_Store
Thumbs.db

# licensing SECRETS — never commit. private.pem signs licenses; if it leaks,
# anyone can forge them. Issued customer licenses live in tools/license-admin/issued/.
tools/license-admin/keys/private.pem
tools/license-admin/issued/
license.dat
storage/license/

# turbo
.turbo/

# playwright
test-results/
playwright-report/

# runtime heartbeat — engine writes this every 5s; never track
storage/crawler.lock

# Docker server-edition: pg-init/*.sql is a COPY of packages/database/prisma/
# {schema.sql,sql/constraints.sql} that build-and-push.mjs refreshes on every
# run — the committed source of truth is the prisma/ copy, not this one.
tools/package/docker/pg-init/*.sql
tools/package/docker/.env
