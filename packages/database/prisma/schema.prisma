// CLG Search — Prisma schema (PostgreSQL 16).
//
// Conventions:
//  - snake_case fields + @@map("snake_case") tables so the raw-SQL CHECK
//    migration (prisma/sql/constraints.sql) has predictable identifiers.
//  - All statuses are enums (no free-text status fields) per spec Section 33.
//
// The criteria_url invariant is enforced by NOT NULL here PLUS a CHECK
// constraint applied via prisma/sql/constraints.sql (Prisma cannot express
// CHECK in-schema). See acceptance criterion #12.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CrawlStatus {
  IDLE
  QUEUED
  DISCOVERING
  VALIDATING
  EXTRACTING
  PARSING
  COMPLETED
  FAILED
  STOPPED
}

enum LinkStatus {
  PENDING
  QUEUED
  VALID_COURSE_PAGE
  VALID_ADMISSION_PAGE
  POSSIBLE_REQUIREMENT_PAGE
  LOW_CONFIDENCE_PAGE
  BROKEN_LINK
  REDIRECTED
  BLOCKED
  DUPLICATE
  NOT_RELEVANT
  PDF_DEFERRED
  // Classified as belonging to the OTHER crawl context (eligibility URL seen
  // during a scholarship crawl or vice versa) — rejected BEFORE any network
  // request. Zero fetches, zero snapshots, zero parse jobs, zero exports.
  REJECTED_CROSS_CONTEXT
}

// One crawl execution = one objective. Contexts are fully isolated: a crawl
// never fetches URLs classified as belonging to the other context.
enum CrawlContextType {
  ELIGIBILITY
  SCHOLARSHIP
}

// Deterministic PRE-FETCH classification of what a URL appears to represent
// (URL structure + anchor text + keyword vocabulary — never an LLM).
enum PageClass {
  COURSE_PAGE
  COURSE_LISTING
  ELIGIBILITY_PAGE
  ADMISSIONS_PAGE
  INTERNATIONAL_ADMISSIONS_PAGE
  SCHOLARSHIP_PAGE
  SCHOLARSHIP_LISTING
  FUNDING_PAGE
  NAVIGATION_PAGE
  DOCUMENT
  IRRELEVANT
  UNKNOWN
}

enum ReviewStatus {
  PENDING
  LOW_CONFIDENCE
  NEEDS_REVIEW
  APPROVED
  REJECTED
  DUPLICATE
}

enum DegreeLevel {
  Bachelor
  Diploma
  Other
}

enum ParserType {
  ai
  rule_based
}

enum JobType {
  DISCOVER
  VALIDATE
  EXTRACT
  PARSE
  EXPORT
}

enum JobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  DEAD_LETTER
}

enum CrawlAction {
  DISCOVER_LINKS
  SCORE_LINK
  VALIDATE_LINK
  EXTRACT_PAGE
  CLEAN_CONTENT
  CHUNK_CONTENT
  PARSE_CRITERIA
  VALIDATE_SNIPPET
  STORE_CRITERIA
  EXPORT_DATA
}

enum LogStatus {
  OK
  WARN
  ERROR
}

enum ExportType {
  CSV
  EXCEL
}

model University {
  id                      String      @id @default(cuid())
  name                    String
  country                 String
  base_url                String
  crawl_status            CrawlStatus @default(IDLE)
  total_links_found       Int         @default(0)
  total_valid_links       Int         @default(0)
  total_courses_extracted Int         @default(0)
  // Manual display + crawl ordering (drag-to-reorder on the Universities page).
  // Lower = earlier. Defaults to 0; new rows are pushed to the end on insert.
  sort_order              Int         @default(0)
  notes                   String?
  created_at              DateTime    @default(now())
  updated_at              DateTime    @updatedAt

  discovered_links DiscoveredLink[]
  page_snapshots   PageSnapshot[]
  course_criteria  CourseCriteria[]
  crawl_logs       CrawlLog[]
  crawl_jobs       CrawlJob[]

  @@index([crawl_status])
  @@index([sort_order])
  @@map("university")
}

model DiscoveredLink {
  id              String     @id @default(cuid())
  university_id   String
  url             String
  final_url       String?
  canonical_url   String?
  url_hash        String
  page_title      String?
  link_text       String?
  link_score      Int        @default(0)
  depth           Int        @default(0)
  status          LinkStatus @default(PENDING)
  http_status     Int?
  is_duplicate    Boolean    @default(false)
  // The crawl context that discovered this link. Contexts are isolated: the same
  // URL may exist once per context (see the 3-part unique below) so a resume of
  // one context never mistakes the OTHER context's visits for its own progress.
  // Rows created before context isolation default to ELIGIBILITY (legacy).
  crawl_context   CrawlContextType @default(ELIGIBILITY)
  // Deterministic pre-fetch classification of what the URL appears to represent
  // (refined post-fetch with the final URL). Drives crawl authorization.
  page_class      PageClass?
  // Inline content-validation (set during the crawl, single pass): true when the
  // page TEXT actually contained entry-requirement / eligibility (or scholarship,
  // per CRAWL_TARGET) evidence — not just a keyword in the URL. `evidence` holds a
  // short proof snippet. Drives the live "Validated URLs" feed on Crawl & Validate.
  content_verified Boolean   @default(false)
  evidence        String?
  // Entry-requirements DEEP-LINK computed during the crawl (the page URL + the
  // anchor of its entry-requirements section/tab/modal, e.g.
  // …/course/MGM102/2/2026#academicentryrequirementsmodal). This is the exact
  // eligibility URL shown LIVE in the Validated feed and carried into the export,
  // so what you watch during the crawl equals the delivered link.
  eligibility_url String?
  screenshot_path String?
  html_path       String?
  text_path       String?
  retry_count     Int        @default(0)
  error_message   String?
  created_at      DateTime   @default(now())
  updated_at      DateTime   @updatedAt

  university     University       @relation(fields: [university_id], references: [id], onDelete: Cascade)
  page_snapshots PageSnapshot[]
  course_criteria CourseCriteria[]
  crawl_logs     CrawlLog[]

  @@unique([university_id, url_hash, crawl_context])
  @@index([university_id, status])
  @@index([university_id, content_verified])
  @@index([university_id, crawl_context])
  @@index([status])
  @@index([link_score])
  @@map("discovered_link")
}

model PageSnapshot {
  id                 String   @id @default(cuid())
  university_id      String
  discovered_link_id String
  // Snapshots are created ONLY for validated targets of the crawl's own context
  // (eligibility: individual course pages). Kept for auditability + parse gating.
  crawl_context      CrawlContextType @default(ELIGIBILITY)
  url                String
  final_url          String
  page_title         String?
  source_language    String?
  raw_html_path      String?
  cleaned_text_path  String?
  screenshot_path    String?
  extracted_text     String?  @db.Text
  created_at         DateTime @default(now())

  university      University     @relation(fields: [university_id], references: [id], onDelete: Cascade)
  discovered_link DiscoveredLink @relation(fields: [discovered_link_id], references: [id], onDelete: Cascade)

  @@index([university_id])
  @@index([discovered_link_id])
  @@map("page_snapshot")
}

model CourseCriteria {
  id                   String       @id @default(cuid())
  university_id        String
  discovered_link_id   String?
  university_name      String
  course_name          String
  canonical_course_key String
  degree_level         DegreeLevel  @default(Other)
  criteria             String?      @db.Text
  // criteria_url: enforced NOT NULL here + CHECK (^https?://, length>0) via
  // prisma/sql/constraints.sql. This is the non-negotiable URL invariant.
  criteria_url         String
  source_snippet       String       @db.Text
  required_subjects    Json         @default("[]")
  minimum_marks        String?
  entrance_exam        String?
  english_requirement  String?
  confidence_score     Float        @default(0)
  parser_type          ParserType
  source_language      String       @default("en")
  review_status        ReviewStatus @default(PENDING)
  reviewed_by          String?
  reviewed_at          DateTime?
  created_at           DateTime     @default(now())
  updated_at           DateTime     @updatedAt

  university      University      @relation(fields: [university_id], references: [id], onDelete: Cascade)
  discovered_link DiscoveredLink? @relation(fields: [discovered_link_id], references: [id], onDelete: SetNull)

  @@unique([university_id, canonical_course_key, criteria_url])
  @@index([university_id])
  @@index([review_status])
  @@index([confidence_score])
  @@index([created_at])
  @@map("course_criteria")
}

model CrawlLog {
  id                 String      @id @default(cuid())
  university_id      String?
  discovered_link_id String?
  action             CrawlAction
  status             LogStatus
  message            String?     @db.Text
  duration_ms        Int?
  error_stack        String?     @db.Text
  created_at         DateTime    @default(now())

  university      University?     @relation(fields: [university_id], references: [id], onDelete: SetNull)
  discovered_link DiscoveredLink? @relation(fields: [discovered_link_id], references: [id], onDelete: SetNull)

  @@index([university_id])
  @@index([action])
  @@index([status])
  @@index([created_at])
  @@map("crawl_log")
}

model CrawlJob {
  id            String    @id @default(cuid())
  university_id String?
  job_type      JobType
  // The single objective of this crawl execution — set at creation, immutable,
  // carried through the BullMQ payload into every request the crawl makes.
  crawl_context CrawlContextType @default(ELIGIBILITY)
  status        JobStatus @default(QUEUED)
  started_at    DateTime?
  finished_at   DateTime?
  stats         Json      @default("{}")
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  university University? @relation(fields: [university_id], references: [id], onDelete: SetNull)

  @@index([university_id])
  @@index([job_type, status])
  @@index([status])
  @@map("crawl_job")
}

model Export {
  id            String     @id @default(cuid())
  export_type   ExportType
  file_path     String
  total_records Int        @default(0)
  scope         String
  created_at    DateTime   @default(now())

  @@index([created_at])
  @@map("export")
}
