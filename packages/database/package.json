{
  "name": "@clg/database",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./repositories": "./src/repositories/index.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate": "prisma db push && prisma db execute --schema prisma/schema.prisma --file prisma/sql/constraints.sql",
    "migrate:deploy": "prisma migrate deploy && prisma db execute --schema prisma/schema.prisma --file prisma/sql/constraints.sql",
    "studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "echo \"(lint placeholder)\""
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@clg/shared": "workspace:*",
    "@prisma/client": "^5.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.2"
  }
}
