{
  "name": "clg-search",
  "version": "1.0.0",
  "private": true,
  "description": "CLG Search — Local-first automated university course eligibility extraction system",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @clg/database generate",
    "db:migrate": "pnpm --filter @clg/database migrate",
    "db:migrate:deploy": "pnpm --filter @clg/database migrate:deploy",
    "db:seed": "pnpm --filter @clg/database seed",
    "db:studio": "pnpm --filter @clg/database studio",
    "api:dev": "pnpm --filter @clg/api dev",
    "crawler:dev": "pnpm --filter @clg/crawler dev",
    "web:dev": "pnpm --filter @clg/web dev"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "tsx": "^4.19.1",
    "vitest": "^2.1.2",
    "@types/node": "^22.7.4",
    "esbuild": "^0.24.0"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.11.1"
    }
  }
}
