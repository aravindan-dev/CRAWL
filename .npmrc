auto-install-peers=true
strict-peer-dependencies=false
# Playwright/Prisma build scripts must be allowed to run on install.
enable-pre-post-scripts=true
# A globally-installed pnpm may differ from the pinned packageManager version
# (e.g. 11.x vs 9.12.0). Without this, turbo's nested `pnpm run` calls hard-fail
# the version check and break `turbo run build/typecheck/test`. Warn instead.
package-manager-strict=false
