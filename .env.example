# ---------------------------------------------------------------------------
# CLG Search — environment configuration
# Copy to `.env` and adjust. Never commit a real `.env`.
# ---------------------------------------------------------------------------

# --- Infrastructure -------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/clgsearch
REDIS_URL=redis://redis:6379

# --- AI provider ----------------------------------------------------------
# One of: ollama | openai | anthropic | gemini | none
AI_PROVIDER=ollama

# Ollama runs on the HOST machine. From inside Docker containers it is reached
# via host.docker.internal. On native Linux this requires the extra_hosts entry
# in docker-compose.yml (host-gateway) — already configured for api/crawler.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Default local extraction models. Pull with:
#   ollama pull qwen3:8b
#   ollama pull gemma3:12b
# Strong laptop? Use OLLAMA_EXTRACTION_MODEL=qwen3:14b
OLLAMA_EXTRACTION_MODEL=qwen3:8b
OLLAMA_FALLBACK_MODEL=gemma3:12b
OLLAMA_TIMEOUT_MS=120000
OLLAMA_MAX_INPUT_CHARS=12000

# Force an explicit context window so 12k-char inputs are NOT silently
# truncated mid-table (Ollama defaults many models to 2048-4096).
OLLAMA_NUM_CTX=8192
# Pure extraction => deterministic. 0 is marginally better than 0.1.
OLLAMA_TEMPERATURE=0

# --- Optional paid providers (for selectively re-running low-confidence) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Crawl tuning ---------------------------------------------------------
CRAWL_CONCURRENCY=2
# Parsing (local LLM) is the bottleneck, not crawling. Tune independently.
PARSE_CONCURRENCY=1
PER_DOMAIN_CONCURRENCY=1
CRAWL_DELAY_MS=2000
MAX_CRAWL_DEPTH=4
MAX_PAGES_PER_UNIVERSITY=300
# Hard wall-clock budget per university (minutes; 0 = no limit). High-value
# eligibility/course pages are crawled first, so N parallel browsers finish N
# universities in ~this many minutes instead of running for hours on huge sites.
MAX_CRAWL_MINUTES=40
# What the crawl focuses on: both | eligibility | scholarship. Set it from the
# Crawl page. Eligibility and scholarship URLs always export to SEPARATE files.
CRAWL_TARGET=both
MIN_LINK_SCORE=40

# --- Storage paths --------------------------------------------------------
SCREENSHOT_STORAGE_PATH=./storage/screenshots
HTML_STORAGE_PATH=./storage/html
TEXT_STORAGE_PATH=./storage/text
EXPORT_STORAGE_PATH=./storage/exports

# --- Crawler identity -----------------------------------------------------
USER_AGENT=CLGSearchBot/1.0 (+https://your-contact-page)

# --- Service ports (host) -------------------------------------------------
API_PORT=4000
WEB_PORT=3000
