# ---------------------------------------------------------------------------
# CLG Search — environment configuration
# Copy to `.env` and adjust. Never commit a real `.env`.
# ---------------------------------------------------------------------------

# --- Infrastructure -------------------------------------------------------
# Host ports docker-compose maps Postgres/Redis to. Only matters if you run
# `docker compose up` directly; scripts/preflight.ps1 (used by setup.bat and
# start.bat) auto-picks a free port and keeps DATABASE_URL/REDIS_URL below in
# sync with whatever it chooses, so you rarely need to touch these by hand.
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/clgsearch
REDIS_URL=redis://redis:6379

# --- AI provider ----------------------------------------------------------
# One of: ollama | openai | anthropic | gemini | none
AI_PROVIDER=ollama

# Ollama runs on the HOST machine. From inside Docker containers it is reached
# via host.docker.internal. On native Linux this requires the extra_hosts entry
# in docker-compose.yml (host-gateway) — already configured for api/crawler.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Default local extraction models. Pull with:
#   ollama pull qwen3:8b
#   ollama pull gemma3:12b
# Strong laptop? Use OLLAMA_EXTRACTION_MODEL=qwen3:14b
OLLAMA_EXTRACTION_MODEL=qwen3:8b
OLLAMA_FALLBACK_MODEL=gemma3:12b
OLLAMA_TIMEOUT_MS=120000
OLLAMA_MAX_INPUT_CHARS=12000

# Force an explicit context window so 12k-char inputs are NOT silently
# truncated mid-table (Ollama defaults many models to 2048-4096).
OLLAMA_NUM_CTX=8192
# Pure extraction => deterministic. 0 is marginally better than 0.1.
OLLAMA_TEMPERATURE=0

# --- Optional paid providers (for selectively re-running low-confidence) ---
OPENAI_API_KEY=
# For standard Anthropic API, just set the key. For AWS Bedrock, also set the base URL and model below.
ANTHROPIC_API_KEY=
# AWS Bedrock configuration (optional, leave empty for standard Anthropic API)
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=
GEMINI_API_KEY=

# --- Crawl tuning ---------------------------------------------------------
CRAWL_CONCURRENCY=2
# Parsing (local LLM) is the bottleneck, not crawling. Tune independently.
PARSE_CONCURRENCY=1
PER_DOMAIN_CONCURRENCY=1
CRAWL_DELAY_MS=2000
MAX_CRAWL_DEPTH=4
MAX_PAGES_PER_UNIVERSITY=300
# Hard wall-clock budget per university (minutes; 0 = no limit). High-value
# eligibility/course pages are crawled first, so N parallel browsers finish N
# universities in ~this many minutes instead of running for hours on huge sites.
MAX_CRAWL_MINUTES=40
# What the crawl focuses on: both | eligibility | scholarship. Set it from the
# Crawl page. Eligibility and scholarship URLs always export to SEPARATE files.
CRAWL_TARGET=both
MIN_LINK_SCORE=40

# --- Runtime optimizations (all default ON; set to false to fall back) -----
# Adaptive throttle: no fixed per-request sleep while the server is healthy;
# CRAWL_DELAY_MS becomes the BACKOFF unit used only after 429/5xx push-back.
CRAWL_ADAPTIVE_THROTTLE=true
# Politeness floor: the adaptive delay never goes below this (ms). Zero-delay
# bursting gets an IP flagged by CDN bot protection — keep a small floor.
CRAWL_MIN_DELAY_MS=100
# HTTP-first discovery: fetch sitemaps/robots over plain HTTP (browser only as a
# fallback) and HTTP-probe likely course/scholarship catalogue & finder URLs
# before broad graph-crawling, so we jump straight to the target inventories.
HTTP_FIRST_DISCOVERY=true
# HTTP-first PAGE FETCHING (the fast lane): discovery/rejected pages are fetched
# with plain HTTP + parsed without a browser (~10-20x cheaper per page); the
# browser serves only JS shells, bot challenges, dynamic finders, and validated
# targets (which need the proof screenshot + parse-grade snapshot).
HTTP_FIRST_FETCH=true
# Dead-branch pruning: stop expanding LOW-tier discover-only links from a URL
# branch after this many visits with zero validated targets. Never affects
# course/eligibility/scholarship candidate links or catalogue seeds.
PRUNE_DEAD_BRANCHES=true
PRUNE_BRANCH_MIN_PAGES=60

# --- Storage paths --------------------------------------------------------
SCREENSHOT_STORAGE_PATH=./storage/screenshots
HTML_STORAGE_PATH=./storage/html
TEXT_STORAGE_PATH=./storage/text
EXPORT_STORAGE_PATH=./storage/exports

# --- Crawler identity -----------------------------------------------------
USER_AGENT=CLGSearchBot/1.0 (+https://your-contact-page)

# --- Service ports (host) -------------------------------------------------
API_PORT=4000
WEB_PORT=3000
# Network interface the API binds to. Default 0.0.0.0 (every interface) is
# what a SHARED SERVER deployment needs — your whole team reaches it from
# their own PCs over the office network at http://<this-server>:API_PORT.
# Set HOST=127.0.0.1 for a single-PC install that should never be reachable
# from the LAN. Do NOT expose this port to the public internet without HTTPS
# and a reverse proxy in front of it (see docs/ADMIN-GUIDE.md).
HOST=0.0.0.0
COOKIE_SECURE=false
# Consumed by apps/web at build/dev time; scripts/preflight.ps1 also writes
# this into apps/web/.env.local so the dashboard always calls the matching
# API_PORT above, even if you change it.
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Licensing ---------------------------------------------------------------
# Shown on the License page and the lock screen when the license needs attention.
NEXT_PUBLIC_VENDOR_CONTACT="your CLG Search account manager"
# Same value, read by the API's license routes/error payloads.
VENDOR_CONTACT="your CLG Search account manager"

# --- Crawl engine behavior -------------------------------------------------
# Auto-start the crawl engine when the API boots (any value other than the
# literal string "false" is treated as on). Set to false to keep the API up
# while managing the engine only from the dashboard's Crawl page.
AUTO_START_CRAWLER=true
# Auto re-enqueue a crawl that stalls (engine running, no pages for a while).
AUTO_RECOVER_CRAWL=true
# Use sitemap.xml discovery in addition to link-following. Same "false"-only
# convention as AUTO_START_CRAWLER above.
ENABLE_SITEMAP=true
